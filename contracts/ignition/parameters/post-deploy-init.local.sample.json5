{
  // 本地样例默认从 Ignition 的 localhost 部署结果中自动读取核心合约地址。
  deployment: {
    source: "ignition",
    deploymentId: "chain-31337",
  },

  options: {
    // 本地链上使用 all 模式时，脚本会自动快进到 timelock 到期后再执行。
    autoMineTimelockOnLocal: true,

    // execute 阶段默认使用的调用者。
    executeCaller: "0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266",

    // funding 阶段默认使用的转账 / mint 发送者。
    defaultFundingSender: "0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266",
  },

  treasury: {
    // 允许 Treasury 管理和拨付的资产。
    allowedTokens: [
      { token: "token", allowed: true },
      { token: "weth", allowed: true },
    ],

    // 允许 Treasury 日常拨付的接收地址。
    allowedRecipients: [
      { recipient: "manager", allowed: true },
      { recipient: "buybackExecutor", allowed: true },
      { recipient: "revenueDistributor", allowed: true },
    ],

    // 各资产的日限额。
    dailySpendCaps: [
      { token: "token", amount: "1000000000000000000000000" },
      { token: "weth", amount: "1000000000000000000000" },
      { token: "native", amount: "10000000000000000000" },
    ],

    // 让业务模块能从 Treasury 拉取或销毁对应资产。
    spenderApprovals: [
      { token: "token", spender: "manager", amount: "500000000000000000000000" },
      { token: "token", spender: "revenueDistributor", amount: "500000000000000000000000" },
      { token: "weth", spender: "buybackExecutor", amount: "1000000000000000000000" },
    ],

    spenderRevocations: [],
  },

  funding: {
    // 给 Treasury 和测试账号补一些原生币，便于本地联调。
    nativeTransfers: [
      { to: "treasury", amount: "5000000000000000000" },
      { to: "0x70997970C51812dc3A010C7d01b50e0d17dc79C8", amount: "10000000000000000000" },
      { to: "0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC", amount: "10000000000000000000" },
    ],

    // 给本地常用测试账号预置多种代币，方便直接测试 swap / pool / order。
    tokenMints: [
      { token: "token", to: "treasury", amount: "180000000000000000000000" },

      { token: "token", to: "0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266", amount: "200000000000000000000000" },
      { token: "token", to: "0x70997970C51812dc3A010C7d01b50e0d17dc79C8", amount: "100000000000000000000000" },
      { token: "token", to: "0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC", amount: "100000000000000000000000" },

      { token: "mockUsdt", to: "0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266", amount: "5000000000000" },
      { token: "mockUsdt", to: "0x70997970C51812dc3A010C7d01b50e0d17dc79C8", amount: "5000000000000" },
      { token: "mockUsdt", to: "0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC", amount: "5000000000000" },

      { token: "mockUsdc", to: "0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266", amount: "5000000000000" },
      { token: "mockUsdc", to: "0x70997970C51812dc3A010C7d01b50e0d17dc79C8", amount: "5000000000000" },
      { token: "mockUsdc", to: "0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC", amount: "5000000000000" },

      { token: "mockWbtc", to: "0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266", amount: "100000000000" },
      { token: "mockWbtc", to: "0x70997970C51812dc3A010C7d01b50e0d17dc79C8", amount: "100000000000" },
      { token: "mockWbtc", to: "0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC", amount: "100000000000" },
    ],

    tokenTransfers: [],
  },

  // 如果后续要把 owner 从 bootstrap 账户移交给多签或治理地址，可以在这里继续配。
  ownershipTransfers: [],
}
